# Optional for cron/shell (not read by Python):
# HERMES_GARMIN_ROOT=/opt/garmin-brief

# Garmin Connect
GARMIN_EMAIL=
GARMIN_PASSWORD=
GARMINTOKENS=~/.garminconnect

# Data & timezone
DATA_DIR=./data
USER_ID=main_user
TIMEZONE=Europe/Lisbon

# OpenRouter (полный текст брифа)
OPENROUTER_API_KEY=
LLM_MODEL=qwen/qwen3.6-35b-a3b

# Telegram (короткий бриф + ссылка)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# URL для ссылки в Telegram (путь: /briefs/YYYY-MM-DD.html)
# Vercel (prod):   https://your-project.vercel.app
# Mac (локально):  http://127.0.0.1:8765  + scripts/serve_brief.py
# VPS (legacy):    http://YOUR_VPS_IP:8765  + BRIEF_HOST=local
BRIEF_PUBLIC_BASE_URL=https://your-project.vercel.app

# Vercel — auto-deploy web/ после каждого брифа (только на VPS)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
